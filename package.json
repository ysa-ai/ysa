{
  "name": "@ysa-ai/ysa",
  "version": "0.4.3",
  "type": "module",
  "description": "Run AI coding agents (Claude, Mistral, other providers coming soon) in parallel inside hardened, isolated containers with git worktree separation.",
  "license": "Apache-2.0",
  "keywords": [
    "ai",
    "agent",
    "sandbox",
    "container",
    "security",
    "podman",
    "claude",
    "parallel",
    "worktree"
  ],
  "homepage": "https://github.com/ysa-ai/ysa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ysa-ai/ysa.git"
  },
  "bugs": {
    "url": "https://github.com/ysa-ai/ysa/issues"
  },
  "files": [
    "src/",
    "container/",
    "out/"
  ],
  "bin": {
    "ysa": "src/cli/index.ts"
  },
  "exports": {
    ".": { "types": "./src/index.ts", "default": "./out/index.js" },
    "./runtime": { "types": "./src/runtime/index.ts", "default": "./out/runtime.js" },
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "bun build src/index.ts --outfile out/index.js --minify --target bun && bun build src/runtime/index.ts --outfile out/runtime.js --minify --target bun",
    "prepublishOnly": "bun run build",
    "build:images": "bash container/build-images.sh",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "docs": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "hono": "^4.11.9",
    "marked": "^17.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
