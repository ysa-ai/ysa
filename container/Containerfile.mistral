FROM python:3.12-alpine

# Install runtime deps + build tools, compile mistral-vibe (tree-sitter needs gcc),
# then strip build tools in the same layer to keep image size down
RUN apk add --no-cache git bash curl jq openssl iptables ip6tables ca-certificates gcc musl-dev && \
    pip install --no-cache-dir mistral-vibe && \
    apk del gcc musl-dev && \
    rm -rf /var/cache/apk/* /tmp/* /root/.cache/pip

# Create non-root user
RUN addgroup -g 1001 agent && adduser -u 1001 -G agent -D -h /home/agent agent

# Workspace dir
RUN mkdir -p /workspace /output && chown agent:agent /workspace /output

# Git branch restriction hook
COPY git-push-guard.sh /usr/local/bin/git-push-guard.sh
RUN chmod +x /usr/local/bin/git-push-guard.sh

# Git safe wrapper — strips dangerous filter configs before each git command
COPY git-safe-wrapper.sh /usr/local/bin/git
RUN chmod +x /usr/local/bin/git

# Harden git against config-based code execution attacks
RUN mkdir -p /usr/local/share/git-hooks && \
    cp /usr/local/bin/git-push-guard.sh /usr/local/share/git-hooks/pre-push && \
    chmod +x /usr/local/share/git-hooks/pre-push

RUN git config --system core.hooksPath /usr/local/share/git-hooks && \
    git config --system core.fsmonitor false && \
    git config --system core.symlinks false && \
    git config --system receive.fsckObjects true && \
    git config --system transfer.fsckObjects true && \
    git config --system safe.directory /workspace && \
    git config --system protocol.file.allow never && \
    git config --system submodule.recurse false

# Remove setuid/setgid bits from ALL binaries
RUN find / -perm /6000 -type f -exec chmod a-s {} + 2>/dev/null || true

# Remove unnecessary utilities
RUN rm -f /usr/bin/passwd /usr/bin/wget /usr/bin/nc /usr/bin/netcat \
         2>/dev/null || true

# Default Vibe config (copied to ~/.vibe at runtime via init script)
RUN mkdir -p /etc/vibe-defaults
COPY vibe-config.toml /etc/vibe-defaults/config.toml

# Network proxy — install shared CA cert so the agent trusts the MITM proxy
COPY ca.pem /usr/local/share/ca-certificates/ysa-proxy-ca.crt
RUN update-ca-certificates

# OCI hook script
COPY oci-network-hook.sh /opt/proxy/oci-network-hook.sh
RUN chmod +x /opt/proxy/oci-network-hook.sh

USER agent

# Lock down git via env vars (same as Claude image)
ENV GIT_CONFIG_COUNT=17 \
    GIT_CONFIG_KEY_0=core.fsmonitor \
    GIT_CONFIG_VALUE_0=false \
    GIT_CONFIG_KEY_1=core.hooksPath \
    GIT_CONFIG_VALUE_1=/usr/local/share/git-hooks \
    GIT_CONFIG_KEY_2=filter.lfs.process \
    GIT_CONFIG_VALUE_2= \
    GIT_CONFIG_KEY_3=filter.lfs.clean \
    GIT_CONFIG_VALUE_3= \
    GIT_CONFIG_KEY_4=credential.helper \
    GIT_CONFIG_VALUE_4= \
    GIT_CONFIG_KEY_5=core.symlinks \
    GIT_CONFIG_VALUE_5=false \
    GIT_CONFIG_KEY_6=protocol.file.allow \
    GIT_CONFIG_VALUE_6=never \
    GIT_CONFIG_KEY_7=submodule.recurse \
    GIT_CONFIG_VALUE_7=false \
    GIT_CONFIG_KEY_8=core.pager \
    GIT_CONFIG_VALUE_8=cat \
    GIT_CONFIG_KEY_9=core.editor \
    GIT_CONFIG_VALUE_9=true \
    GIT_CONFIG_KEY_10=core.sshCommand \
    GIT_CONFIG_VALUE_10= \
    GIT_CONFIG_KEY_11=core.askPass \
    GIT_CONFIG_VALUE_11= \
    GIT_CONFIG_KEY_12=core.gitProxy \
    GIT_CONFIG_VALUE_12= \
    GIT_CONFIG_KEY_13=diff.external \
    GIT_CONFIG_VALUE_13= \
    GIT_CONFIG_KEY_14=gpg.program \
    GIT_CONFIG_VALUE_14= \
    GIT_CONFIG_KEY_15=sequence.editor \
    GIT_CONFIG_VALUE_15=true \
    GIT_CONFIG_KEY_16=protocol.ext.allow \
    GIT_CONFIG_VALUE_16=never

WORKDIR /workspace

ENTRYPOINT ["/bin/bash"]
